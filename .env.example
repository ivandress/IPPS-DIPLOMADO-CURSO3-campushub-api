# ============================================================
#  CampusHub · variables de entorno (PLANTILLA)
#  Copia este archivo como .env y ve rellenando los valores
#  A MEDIDA que cada lab te lo pida. NO todas hacen falta al inicio.
#
#  ⚠️  NUNCA subas tu archivo .env al repo (ya está en .gitignore).
#      Este .env.example SÍ se sube; el .env con tus secretos NO.
# ============================================================

# Puerto donde escucha la API (opcional, por defecto 3000)
PORT=3000

# --- Cap 6: MongoDB (Lab 15+) ---
# Cadena de conexión a tu base de datos MongoDB (Atlas o local)
MONGO_URI=

# --- Cap 8: Autenticación (Lab 25, login) ---
# Secreto para firmar los tokens JWT (usa una cadena larga y aleatoria)
JWT_SECRET=

# --- Cap 9: Correo (Lab 28, Nodemailer) ---
# Cuenta de Gmail y "contraseña de aplicación" para enviar correos
MAIL_USER=
MAIL_APP_PASSWORD=

# --- Cap 9: Login con Google (Lab 30, OAuth) ---
# Credenciales del proyecto en Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL a la que Google devuelve tras autenticar. Debe estar registrada IGUAL en
# Google Cloud Console → Credenciales → URIs de redirección autorizadas.
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# URL del frontend (para CORS y para la redirección tras el login con Google).
# Si el front corre en otro puerto, ajústalo. Acepta varios separados por coma.
FRONTEND_URL=http://localhost:5173
